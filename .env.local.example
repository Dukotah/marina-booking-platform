# ---------------------------------------------------------------------------
# LOCAL DEV TEMPLATE — copy to .env to run the whole stack with ZERO external
# accounts (local Postgres + dev stubs for auth/payments/email).
#
#   cp .env.local.example .env
#   bash scripts/setup-local.sh   # one-time: db + migrate + seed
#   bash scripts/dev-local.sh     # boot API + web + admin
#
# See docs/DEV-LOCAL.md. None of these values are secret. When you later wire the
# real services, put their keys in a separate (gitignored) .env — do not commit.
# ---------------------------------------------------------------------------

# --- Database (local Postgres; role+db both "marina", see scripts/setup-local.sh) ---
DATABASE_URL="postgresql://marina:marina@127.0.0.1:5432/marina"
DIRECT_URL="postgresql://marina:marina@127.0.0.1:5432/marina"
# Non-bypass app role so row-level security (tenant isolation between clients) is
# actually enforced locally, like production. Created by setup-local.sh / db:approle.
APP_DATABASE_URL="postgresql://app_user:appuserpass123@127.0.0.1:5432/marina"
APP_DB_PASSWORD="appuserpass123"

# --- Auth: Clerk OFF → dev shim (admin uses an OWNER fallback; API uses x-dev-staff-id) ---
REQUIRE_CLERK_AUTH="false"

# --- Payments: no Stripe → simulate charges/refunds (NEVER active in production) ---
DEV_FAKE_PAYMENTS="true"
NEXT_PUBLIC_DEV_FAKE_PAYMENTS="true"

# --- Email: leave RESEND_API_KEY empty → notifications log + no-op (never block a flow) ---

# --- App wiring ---
PORT="3001"
API_URL="http://localhost:3001"
OPERATOR_SLUG="lake-sonoma"
APP_BASE_DOMAIN="localhost:3000"
NODE_ENV="development"

# --- White-label brand (seed operator = Lake Sonoma Marina) ---
BRAND_NAME="Lake Sonoma Marina"
BRAND_COLOR="#0e7490"
