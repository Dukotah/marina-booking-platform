{
  "name": "@marina/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "rls": "node --experimental-strip-types scripts/apply-rls.ts",
    "seed": "node --experimental-strip-types prisma/seed.ts",
    "studio": "prisma studio",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "node --experimental-strip-types prisma/seed.ts"
  },
  "dependencies": {
    "@marina/types": "workspace:*",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prisma": "^6.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
