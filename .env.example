# Copy to .env and fill in. Never commit .env.
# See docs/ROADMAP.md "Blocked-on-owner" for where each value comes from.

# --- Database (Neon Postgres) ---
# Pooled connection string for the app (Neon "Pooled connection").
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
# Direct connection string for migrations (Neon "Direct connection", no pgbouncer).
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Master switch for real Clerk auth (admin app + API). Leave "false" until the Clerk
# dashboard has sign-in URLs + your first staff user — until then the apps use the dev
# OWNER fallback / x-dev-staff-id shim so everything stays usable. Flip to "true" to
# require real sign-in everywhere. (See docs/DECISIONS.md D-012.)
REQUIRE_CLERK_AUTH="false"
# Where Clerk's components live + where to land after auth (used when enforcement is on).
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# --- Payments (Stripe test mode first) ---
# Server (api): secret key + webhook signing secret.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Browser (web): publishable key — safe to expose. pk_test_… in test mode.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Customer auth (email OTP → session) ---
# HMAC secret that signs customer OTP challenges + session tokens (apps/api auth
# route, roadmap 0.7). Stateless: there is NO DB-backed session store, so rotating
# this value invalidates every outstanding customer session/OTP. Generate a strong
# random value (e.g. `openssl rand -base64 32`). If unset, the API falls back to an
# INSECURE dev default and warns on startup — set this before going to production.
AUTH_SECRET=""

# --- Email (Resend) ---
RESEND_API_KEY=""

# --- App ---
APP_BASE_DOMAIN="localhost:3000"
# Marina API origin used by the customer portal (apps/web lib/api.ts).
# `API_URL` is read server-side (Server Components / route handlers). The
# availability + reschedule pickers fetch from the BROWSER, where only
# NEXT_PUBLIC_* vars are inlined — so set NEXT_PUBLIC_API_URL to the same origin
# (it's just the public API base, safe to expose). Without it, browser fetches
# fall back to http://localhost:3001 in production.
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# --- Observability (optional; error capture seam) ---
# The apps + API have a tiny captureError() seam (lib/observability) that logs
# structured errors today and is ready to forward to a real SDK (e.g. Sentry)
# once installed. Leave these UNSET to keep it a no-op console logger. When set,
# the seam logs that it WOULD forward (no @sentry/* package is installed yet —
# see the SDK plug-in comment in each observability.ts).
# Server-side (apps/api):
# SENTRY_DSN=""
# Browser (apps/web + apps/admin error boundaries):
# NEXT_PUBLIC_SENTRY_DSN=""
